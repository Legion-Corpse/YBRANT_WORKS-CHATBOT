# --- Required ---------------------------------------------------------------
# OpenAI API key (paid). Chat fails until set; /api/ready reports not-ready.
OPENAI_API_KEY=sk-...
# The persistent OpenAI vector store searched on every chat turn. Create it once
# (scripts/ingest.py creates one and logs the id if this is empty) and pin it here
# so restarts and re-ingests reuse the same store.
OPENAI_VECTOR_STORE_ID=vs_...

# --- OpenAI tuning (defaults shown) ----------------------------------------
# Model id is office-supplied; correct it here if the account exposes a different id.
# OPENAI_MODEL=gpt-5.4-nano-2026-03-17
# OPENAI_SCORE_THRESHOLD=0.4      # file_search min relevance; higher = stricter (0.7 missed real content in testing)
# OPENAI_MAX_NUM_RESULTS=5        # max chunks fed to the model per turn
# OPENAI_TEMPERATURE=0.0
# OPENAI_MAX_OUTPUT_TOKENS=512    # answers are short; low cap trims token cost
# OPENAI_TIMEOUT_SECONDS=30
# OPENAI_MAX_RETRIES=2

# --- Ingestion --------------------------------------------------------------
# SITE_BASE_URL=https://www.ybrantworks.com
# WEB_RENDER_JS=True              # JS-render web pages via Playwright at ingest
# WEB_RENDER_TIMEOUT_MS=15000

# CORS: which sites' browser JS may call this API. Defaults to the live site
# (safe). Override ONLY for local dev:
#   Local dev (widget demo, file://):   CORS_ORIGINS=*
#   PRODUCTION (lock to the host site):  CORS_ORIGINS=https://www.ybrantworks.com
# CORS_ORIGINS=https://www.ybrantworks.com

# Admin token for the HTTP ingest endpoints (/api/ingest/*). FAIL-CLOSED: if this
# is unset, the HTTP ingest API is disabled and returns 401 (the CLI ingest path
# still works). Set a long random value to enable HTTP ingestion.
# INGEST_API_KEY=
# MAX_UPLOAD_BYTES=10485760

# Per-IP request limits (slowapi) — first-line abuse/cost guard on the paid key.
# CHAT_RATE_LIMIT=20/minute
# INGEST_RATE_LIMIT=5/minute

# Hard aggregate ceiling on real OpenAI chat calls per UTC day (caps total spend
# even if the per-IP limit is evaded across many IPs). In-process; resets daily.
# Default 100 suits ~5 users/month; raise it if real volume grows.
# DAILY_REQUEST_CAP=100

# Idle timeout: a session is "ended" after this many seconds of inactivity — the
# next message starts a fresh OpenAI conversation (no prior-turn context). Keep
# it >= the widget's data-idle-minutes (default 5 min on both sides).
# SESSION_TTL_SECONDS=300
# MAX_SESSIONS=1000

# Answer cache (first-turn questions only; cleared on ingest). Long TTL because
# site content changes rarely; persisted to disk so restarts keep their hits.
# CACHE_ENABLED=True
# CACHE_TTL_SECONDS=86400
# CACHE_MAX_ENTRIES=256
# CACHE_PERSIST=True
